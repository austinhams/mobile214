<%- include('partials/head', { title: 'Server Error – mobile214' }) %>
<%- include('partials/nav') %>

<main class="max-w-md mx-auto px-4 py-20 text-center">
  <p class="text-6xl font-black text-gray-200 mb-4">500</p>
  <h1 class="text-2xl font-bold text-gray-800 mb-2">Something went wrong</h1>
  <p class="text-gray-500 mb-8">An unexpected error occurred. Please try again in a moment.</p>
  <% if (locals.errorId) { %>
  <p class="text-xs text-gray-400 mb-6">Error ID: <code class="font-mono"><%= errorId %></code></p>
  <% } %>
  <a href="/" class="inline-block bg-brand-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-brand-700 transition">
    Go home
  </a>
</main>

<%- include('partials/foot') %>
