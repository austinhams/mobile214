<%- include('partials/head', { title: 'Create Account – mobile214' }) %>
<%- include('partials/nav') %>

<main class="max-w-md mx-auto px-4 py-10">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">Create account</h1>
    <p class="text-sm text-gray-500 mb-6">Start tracking your events today.</p>

    <% if (error) { %>
    <div class="mb-5 flex items-start gap-2 bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3">
      <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <%= error %>
    </div>
    <% } %>

    <form method="POST" action="/register" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email"
               class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
               placeholder="you@example.com" />
      </div>
      <div>
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <input type="password" id="password" name="password" required autocomplete="new-password"
               class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
               placeholder="Min. 6 characters" />
      </div>
      <div>
        <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">Confirm password</label>
        <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password"
               class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition"
               placeholder="Repeat password" />
      </div>
      <button type="submit"
              class="w-full bg-brand-600 text-white font-semibold py-3 rounded-xl hover:bg-brand-700 transition text-sm mt-2">
        Create account
      </button>
    </form>

    <p class="text-center text-sm text-gray-500 mt-6">
      Already have an account?
      <a href="/login" class="text-brand-600 font-medium hover:underline">Sign in</a>
    </p>
  </div>
</main>

<script>
(function () {
  const form = document.querySelector('form[action="/register"]');
  const emailEl = document.getElementById('email');
  const passwordEl = document.getElementById('password');
  const confirmEl = document.getElementById('confirm_password');

  function fieldError(el, msg) {
    el.classList.remove('border-gray-300');
    el.classList.add('border-red-500');
    let err = el.parentElement.querySelector('.field-error');
    if (!err) {
      err = document.createElement('p');
      err.className = 'field-error text-red-500 text-xs mt-1';
      el.parentElement.appendChild(err);
    }
    err.textContent = msg;
  }
  function fieldOk(el) {
    el.classList.remove('border-red-500');
    el.classList.add('border-gray-300');
    el.parentElement.querySelector('.field-error')?.remove();
  }

  function validateEmail() {
    const v = emailEl.value.trim();
    if (!v) { fieldError(emailEl, 'Email is required.'); return false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) { fieldError(emailEl, 'Enter a valid email address.'); return false; }
    fieldOk(emailEl); return true;
  }
  function validatePassword() {
    const v = passwordEl.value;
    if (!v) { fieldError(passwordEl, 'Password is required.'); return false; }
    if (v.length < 6) { fieldError(passwordEl, 'Password must be at least 6 characters.'); return false; }
    fieldOk(passwordEl); return true;
  }
  function validateConfirm() {
    if (!confirmEl.value) { fieldError(confirmEl, 'Please confirm your password.'); return false; }
    if (confirmEl.value !== passwordEl.value) { fieldError(confirmEl, 'Passwords do not match.'); return false; }
    fieldOk(confirmEl); return true;
  }

  emailEl.addEventListener('blur', validateEmail);
  emailEl.addEventListener('input', () => { if (emailEl.parentElement.querySelector('.field-error')) validateEmail(); });
  passwordEl.addEventListener('blur', validatePassword);
  passwordEl.addEventListener('input', () => {
    if (passwordEl.parentElement.querySelector('.field-error')) validatePassword();
    if (confirmEl.parentElement.querySelector('.field-error')) validateConfirm();
  });
  confirmEl.addEventListener('blur', validateConfirm);
  confirmEl.addEventListener('input', () => { if (confirmEl.parentElement.querySelector('.field-error')) validateConfirm(); });
  form.addEventListener('submit', e => {
    const ok = [validateEmail(), validatePassword(), validateConfirm()].every(Boolean);
    if (!ok) {
      e.preventDefault();
      // Focus the first field that has an error
      const first = form.querySelector('.border-red-500');
      if (first) first.focus();
    }
  });

  // If the server returned an error, focus the email field on page load
  <% if (error) { %>emailEl.focus();<% } %>
}());
</script>

<%- include('partials/foot') %>
