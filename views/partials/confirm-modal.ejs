<!-- Confirm Delete Modal -->
<div id="confirm-modal"
     class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
  <div class="bg-white w-full max-w-sm rounded-2xl shadow-xl p-6">
    <h2 class="text-lg font-bold text-gray-900 mb-2">Are you sure?</h2>
    <p id="confirm-modal-message" class="text-sm text-gray-500 mb-6"></p>
    <div class="flex gap-3">
      <button type="button"
              onclick="closeConfirmModal()"
              class="flex-1 border border-gray-300 text-gray-700 font-semibold py-2.5 rounded-xl hover:bg-gray-50 transition text-sm">
        Cancel
      </button>
      <button type="button"
              id="confirm-modal-confirm"
              class="flex-1 bg-red-600 text-white font-semibold py-2.5 rounded-xl hover:bg-red-700 transition text-sm">
        Delete
      </button>
    </div>
  </div>
</div>

<script>
  let _confirmTrigger = null;

  function openConfirmModal(message, onConfirm, trigger) {
    _confirmTrigger = trigger || null;
    document.getElementById('confirm-modal-message').textContent = message;
    document.getElementById('confirm-modal-confirm').onclick = function () {
      closeConfirmModal();
      onConfirm();
    };
    document.getElementById('confirm-modal').classList.remove('hidden');
    document.getElementById('confirm-modal-confirm').focus();
  }

  function closeConfirmModal() {
    document.getElementById('confirm-modal').classList.add('hidden');
    if (_confirmTrigger) { _confirmTrigger.focus(); _confirmTrigger = null; }
  }
</script>
