{
  "name": "mobile214",
  "version": "1.0.0",
  "description": "Mobile-friendly event update tracker",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --minify && node scripts/fingerprint-css.js",
    "dev": "concurrently \"nodemon app.js\" \"tailwindcss -i ./public/css/input.css -o ./public/css/tailwind.css --watch\"",
    "dev:kill": "lsof -ti:3000 | xargs kill -9"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^3.2.2",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.3",
    "tailwindcss": "^4.2.1"
  }
}
