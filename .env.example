# Server
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
LOG_LEVEL=debug

# PostgreSQL — either set DATABASE_URL or the individual variables below
DATABASE_URL=postgresql://user:pass@host:5432/mobile214

# Application base URL (used in verification email links)
APP_BASE_URL=http://localhost:3000

# SMTP — leave blank to use Ethereal catch-all (dev only, emails not delivered)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=noreply@example.com